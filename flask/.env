# Flask
FLASK_ENV=development
SECRET_KEY=change-me-super-secret-key
DEBUG=True

# MongoDB
MONGO_URI=mongodb://localhost:27017/immo_madagascar

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 min en secondes
JWT_REFRESH_TOKEN_EXPIRES=604800    # 7 jours

# Bcrypt
BCRYPT_LOG_ROUNDS=12

# OAuth Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/oauth/google/callback

# Mail (vérification email)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ML
ML_MODEL_PATH=app/ml/model.pkl
ML_ENCODERS_PATH=app/ml/encoders.pkl
ML_SCALER_PATH=app/ml/scaler.pkl
ML_FEATURES_PATH=app/ml/features.pkl